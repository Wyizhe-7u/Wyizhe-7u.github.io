<view class="container">
  <view class="cart-header">
    <text class="cart-title">🛒 购物车</text>
    <text class="cart-count">共{{totalCount}}件商品</text>
  </view>

  <scroll-view scroll-y class="cart-scroll" wx:if="{{cart.length > 0}}">
    <view class="cart-list">
      <view wx:for="{{cart}}" wx:key="id" class="cart-item">
        <image class="cart-image" src="https://a0ai.marscode.cn/api/ide/v1/text_to_image?prompt={{item.image}}&image_size=square" mode="aspectFill"></image>
        <view class="cart-info">
          <view class="cart-name">{{item.name}}</view>
          <view class="cart-price">¥{{item.price.toFixed(2)}}</view>
          <view class="cart-quantity">
            <view class="qty-btn minus" bindtap="decreaseQty" data-id="{{item.id}}">-</view>
            <text class="qty-num">{{item.quantity}}</text>
            <view class="qty-btn plus" bindtap="increaseQty" data-id="{{item.id}}">+</view>
          </view>
        </view>
        <view class="cart-delete" bindtap="deleteItem" data-id="{{item.id}}">
          <text class="delete-icon">×</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="empty-cart" wx:else>
    <view class="empty-icon">🛒</view>
    <view class="empty-text">购物车是空的</view>
    <view class="empty-hint">快去挑选美味吧</view>
    <button class="empty-btn" bindtap="goToOrder">去点单</button>
  </view>

  <view class="cart-footer" wx:if="{{cart.length > 0}}">
    <view class="footer-left">
      <text class="footer-label">合计:</text>
      <text class="footer-total">¥{{totalPrice.toFixed(2)}}</text>
    </view>
    <button class="footer-checkout" bindtap="checkout">结算</button>
  </view>
</view>