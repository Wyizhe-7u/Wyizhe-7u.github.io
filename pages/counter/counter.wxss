.counter-display {
  text-align: center;
  padding: 40rpx 0;
}

.counter-label {
  font-size: 28rpx;
  color: #888888;
  margin-bottom: 20rpx;
}

.counter-value {
  font-size: 120rpx;
  font-weight: bold;
  color: #667eea;
  line-height: 1.2;
}

.button-group {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin: 40rpx 0;
}

.btn-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  transition: all 0.2s;
}

.btn-circle:active {
  transform: scale(0.95);
}

.btn-increase {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.btn-decrease {
  background: #f0f0f0;
  color: #666666;
}

.btn-reset {
  background: #fff3cd;
  color: #856404;
}

.btn-icon {
  font-size: 48rpx;
}

.stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-top: 1rpx solid #eee;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
}

.stat-label {
  font-size: 24rpx;
  color: #888888;
  margin-top: 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.history-list {
  max-height: 400rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-time {
  font-size: 26rpx;
  color: #999999;
}

.history-action {
  font-size: 28rpx;
  font-weight: bold;
}

.empty-history {
  text-align: center;
  color: #999999;
  padding: 40rpx 0;
  font-size: 28rpx;
}