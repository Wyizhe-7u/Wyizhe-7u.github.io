<view class="container">
  <view class="banner">
    <view class="banner-content">
      <text class="banner-title">🍔 美味餐厅</text>
      <text class="banner-subtitle">在线点单，美味送到家</text>
      <button class="banner-btn" bindtap="goToOrder">立即点单 →</button>
    </view>
  </view>

  <view class="quick-actions">
    <view class="action-item" bindtap="goToOrder">
      <view class="action-icon">🍟</view>
      <text class="action-text">美食点单</text>
    </view>
    <view class="action-item" bindtap="goToCart">
      <view class="action-icon">🛒</view>
      <text class="action-text">购物车</text>
      <view class="action-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
    </view>
    <view class="action-item">
      <view class="action-icon">⭐</view>
      <text class="action-text">我的收藏</text>
    </view>
    <view class="action-item">
      <view class="action-icon">📞</view>
      <text class="action-text">联系我们</text>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">🔥 热销推荐</text>
      <text class="card-more">查看全部 →</text>
    </view>
    <scroll-view scroll-x class="hot-scroll">
      <view class="hot-list">
        <view wx:for="{{hotItems}}" wx:key="id" class="hot-item" bindtap="goToOrder">
          <image class="hot-image" src="https://a0ai.marscode.cn/api/ide/v1/text_to_image?prompt={{item.image}}&image_size=square" mode="aspectFill"></image>
          <text class="hot-name">{{item.name}}</text>
          <text class="hot-price">¥{{item.price.toFixed(2)}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">🎉 今日特惠</text>
    </view>
    <view class="discount-item">
      <view class="discount-left">
        <text class="discount-tag">限时优惠</text>
        <text class="discount-title">超值套餐A</text>
        <text class="discount-desc">汉堡+薯条+可乐</text>
      </view>
      <view class="discount-right">
        <text class="discount-price">¥45</text>
        <text class="discount-original">¥58</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">📋 门店信息</text>
    </view>
    <view class="store-info">
      <view class="info-row">
        <text class="info-icon">📍</text>
        <text class="info-text">北京市朝阳区建国路88号</text>
      </view>
      <view class="info-row">
        <text class="info-icon">⏰</text>
        <text class="info-text">营业时间：09:00 - 22:00</text>
      </view>
      <view class="info-row">
        <text class="info-icon">📞</text>
        <text class="info-text">订餐热线：400-888-8888</text>
      </view>
    </view>
  </view>
</view>