.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.category-scroll {
  white-space: nowrap;
  background: #ffffff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 30rpx;
}

.category-item {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s;
}

.category-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.menu-scroll {
  height: calc(100vh - 260rpx);
}

.menu-list {
  padding: 20rpx;
}

.menu-item {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.menu-info {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.menu-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999999;
  flex: 1;
}

.menu-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.menu-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.menu-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  transition: all 0.2s;
}

.action-btn.plus {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.action-btn.minus {
  background: #f0f0f0;
  color: #666666;
}

.action-btn:active {
  transform: scale(0.9);
}

.action-count {
  font-size: 28rpx;
  color: #666666;
  min-width: 40rpx;
  text-align: center;
}